{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "custom-new-item-command-set": {
      "components": [
        {
          "entrypoint": "./lib/extensions/customNewItem/CustomNewItemCommandSet.js",
          "manifest": "./src/extensions/customNewItem/CustomNewItemCommandSet.manifest.json"
        }
      ]
    },
    "external-form-bridge-form-customizer": {
      "components": [
        {
          "entrypoint": "./lib/extensions/externalFormBridge/ExternalFormBridgeFormCustomizer.js",
          "manifest": "./src/extensions/externalFormBridge/ExternalFormBridgeFormCustomizer.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "CustomNewItemCommandSetStrings": "lib/extensions/customNewItem/loc/{locale}.js",
    "ExternalFormBridgeFormCustomizerStrings": "lib/extensions/externalFormBridge/loc/{locale}.js"
  }
}